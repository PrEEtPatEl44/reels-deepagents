# Copy to .env and fill in your keys.
#
# After `pip install -r requirements.txt`, run ONCE to install Playwright browsers
# that crawl4ai uses under the hood:
#
#   crawl4ai-setup
#   # or, equivalently: python -m playwright install chromium --with-deps
#
# System libs required for cairosvg (Debian/Ubuntu/WSL):
#   sudo apt-get install -y libcairo2 libpango-1.0-0 libgdk-pixbuf2.0-0

ANTHROPIC_API_KEY=sk-ant-...

# LangSmith tracing + Studio (optional). Tracing surfaces all node/tool calls
# in https://smith.langchain.com; Studio (`langgraph dev`) reads these too.
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agents
