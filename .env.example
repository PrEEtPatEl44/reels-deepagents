# Copy to .env and fill in your keys.
#
# System libs required for cairosvg (Debian/Ubuntu/WSL):
#   sudo apt-get install -y libcairo2 libpango-1.0-0 libgdk-pixbuf2.0-0
#
# The ScrapeGraph MCP server is launched via `uvx scrapegraph-mcp` at runtime.
# Make sure `uvx` (from astral-sh/uv) is installed and on PATH.

ANTHROPIC_API_KEY=sk-ant-...
SGAI_API_KEY=sgai-...
